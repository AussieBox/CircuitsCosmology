{
  "schemaVersion": 1,
  "id": "ccosmo",
  "version": "${version}",
  "name": "Circuit's Cosmology",
  "description": "A mod containing the many magical objects discovered by Dr. C. Weaver.",
  "authors": ["Circuitweaver (aka. AussieBox)"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/ccosmo/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "org.aussiebox.ccosmo.client.CCOSMOClient"
    ],
    "main": [
      "org.aussiebox.ccosmo.CCOSMO"
    ],
    "cardinal-components": [
      "org.aussiebox.ccosmo.CCOSMOComponents"
    ],
    "jei_mod_plugin": [
      "org.aussiebox.ccosmo.client.jei.JEIPlugin"
    ],
    "mixinsquared": [
      "org.aussiebox.ccosmo.mixin.ModMixinCanceller"
    ]
  },
  "custom": {
    "cardinal-components": [
      "ccosmo:shimmer_component",
      "ccosmo:trinket_component",
      "ccosmo:dragonflame_cactus_component"
    ]
  },
  "mixins": [
    "ccosmo.mixins.json",
    {
      "config": "ccosmo.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cardinal-components-base": "${cca_version}",
    "cardinal-components-entity": "${cca_version}",
    "cardinal-components-world": "${cca_version}",
    "trinkets": "${trinkets_version}"
  }
}
